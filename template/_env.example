# URL base da API consumida pelo HttpClient (deixe vazio para usar dados mock locais)
VITE_API_BASE_URL=

# Modo da aplicacao: "development" habilita bypass de autenticacao com token fixo
VITE_APP_MODE=development

# Token usado no modo development para o header x-dev-token / bypass de login
VITE_DEV_TOKEN=dev-token-local
